{
  "name": "pdf-reader-pro",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Professional PDF reader, annotator, and document manager",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:android": "cross-env CAPACITOR=true tsc -b && cross-env CAPACITOR=true vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "cap:sync": "npm run build:android && npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:run": "npm run cap:sync && npx cap run android"
  },
  "dependencies": {
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/filesystem": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^4.9.155",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^25.3.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "dotenv": "^17.3.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "vite-plugin-static-copy": "^2.3.0",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0"
  }
}
